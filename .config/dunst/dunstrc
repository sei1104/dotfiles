[global]
monitor = 1
font = Jetbrains mono Nerd 14
width = 300
hight = (0,600)
frame_color = "#89b4fa"
separator_color= frame
highlight = "#89b4fa"
min_icon_size = 64
timeout = 5

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
